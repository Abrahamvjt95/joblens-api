# OpenSearch
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_INDEX=job-listings

# AWS (local dev uses dummy values with LocalStack)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
S3_BUCKET_RAW=joblens-raw
S3_BUCKET_NORMALIZED=joblens-normalized

# Job API keys
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# Adzuna countries to fetch (comma-separated)
ADZUNA_COUNTRIES=gb,pt,de,es,fr

# The Muse (no auth needed — leave empty)
THEMUSE_API_KEY=

# Remotive (no auth needed — leave empty)
REMOTIVE_CATEGORIES=software-dev,devops-sysadmin,data

# Arbeitnow (no auth needed — leave empty)
ARBEITNOW_TAGS=python,java,angular,typescript,node,react
